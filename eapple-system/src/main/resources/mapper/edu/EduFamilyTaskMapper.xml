<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.eapple.system.mapper.edu.EduFamilyTaskMapper">

    <resultMap id="EduFamilyTaskResult" type="EduFamilyTask">
        <id property="taskId" column="task_id"/>
        <result property="parentUserId" column="parent_user_id"/>
        <result property="parentName" column="parent_name"/>
        <result property="studentUserId" column="student_user_id"/>
        <result property="studentName" column="student_name"/>
        <result property="taskTitle" column="task_title"/>
        <result property="taskType" column="task_type"/>
        <result property="taskContent" column="task_content"/>
        <result property="rewardPoints" column="reward_points"/>
        <result property="rewardText" column="reward_text"/>
        <result property="dueDate" column="due_date"/>
        <result property="proofImages" column="proof_images"/>
        <result property="studentFeedback" column="student_feedback"/>
        <result property="parentComment" column="parent_comment"/>
        <result property="status" column="status"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <sql id="taskSelect">
        select task_id, parent_user_id, parent_name, student_user_id, student_name, task_title, task_type,
               task_content, reward_points, reward_text, due_date, proof_images, student_feedback,
               parent_comment, status, create_by, create_time, update_by, update_time, remark
        from edu_family_task
    </sql>

    <sql id="taskWhere">
        <where>
            <if test="parentUserId != null">
                and parent_user_id = #{parentUserId}
            </if>
            <if test="studentUserId != null">
                and student_user_id = #{studentUserId}
            </if>
            <if test="boundStudentUserIds != null and boundStudentUserIds.size > 0">
                and student_user_id in
                <foreach collection="boundStudentUserIds" item="studentId" open="(" separator="," close=")">
                    #{studentId}
                </foreach>
            </if>
            <if test="boundStudentUserIds != null and boundStudentUserIds.size == 0">
                and 1 = 0
            </if>
            <if test="taskTitle != null and taskTitle != ''">
                and task_title like concat('%', #{taskTitle}, '%')
            </if>
            <if test="taskType != null and taskType != ''">
                and task_type = #{taskType}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
    </sql>

    <select id="selectTaskById" parameterType="Long" resultMap="EduFamilyTaskResult">
        <include refid="taskSelect"/>
        where task_id = #{taskId}
    </select>

    <select id="selectTaskList" parameterType="EduFamilyTask" resultMap="EduFamilyTaskResult">
        <include refid="taskSelect"/>
        <include refid="taskWhere"/>
        order by ifnull(update_time, create_time) desc, task_id desc
        <if test="params.limitTop != null">
            limit #{params.limitTop}
        </if>
    </select>

    <select id="countTasks" parameterType="EduFamilyTask" resultType="Long">
        select count(1) from edu_family_task
        <include refid="taskWhere"/>
    </select>

    <insert id="insertTask" parameterType="EduFamilyTask" useGeneratedKeys="true" keyProperty="taskId">
        insert into edu_family_task
        (parent_user_id, parent_name, student_user_id, student_name, task_title, task_type, task_content,
         reward_points, reward_text, due_date, status, remark, create_by, create_time)
        values
        (#{parentUserId}, #{parentName}, #{studentUserId}, #{studentName}, #{taskTitle}, #{taskType}, #{taskContent},
         #{rewardPoints}, #{rewardText}, #{dueDate}, #{status}, #{remark}, #{createBy}, sysdate())
    </insert>

    <update id="updateTask" parameterType="EduFamilyTask">
        update edu_family_task
        <set>
            <if test="taskTitle != null">task_title = #{taskTitle},</if>
            <if test="taskType != null">task_type = #{taskType},</if>
            <if test="taskContent != null">task_content = #{taskContent},</if>
            <if test="rewardPoints != null">reward_points = #{rewardPoints},</if>
            <if test="rewardText != null">reward_text = #{rewardText},</if>
            <if test="dueDate != null">due_date = #{dueDate},</if>
            <if test="proofImages != null">proof_images = #{proofImages},</if>
            <if test="studentFeedback != null">student_feedback = #{studentFeedback},</if>
            <if test="parentComment != null">parent_comment = #{parentComment},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            update_time = sysdate()
        </set>
        where task_id = #{taskId}
    </update>

    <delete id="deleteTaskByIds" parameterType="Long">
        delete from edu_family_task where task_id in
        <foreach collection="array" item="taskId" open="(" separator="," close=")">
            #{taskId}
        </foreach>
    </delete>

    <select id="sumApprovedPoints" resultType="Integer">
        select ifnull(sum(reward_points), 0)
        from edu_family_task
        where status = '2'
        <if test="studentUserId != null">
            and student_user_id = #{studentUserId}
        </if>
        <if test="parentUserId != null">
            and parent_user_id = #{parentUserId}
        </if>
    </select>
</mapper>
